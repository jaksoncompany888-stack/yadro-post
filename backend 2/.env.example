# Yadro Post Unified - Configuration

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/yadro_post

# AI
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-proj-your-key-here

# Telegram
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHH

# VK
VK_APP_ID=your_app_id
VK_APP_SECRET=your_app_secret

# Redis (для Celery, опционально)
REDIS_URL=redis://localhost:6379/0

# Monitoring (опционально)
SENTRY_DSN=https://your-sentry-dsn

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=true
